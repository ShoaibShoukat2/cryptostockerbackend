# =============================================================================
# Crypto Stacker - Backend Environment Variables
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED (Production)
# -----------------------------------------------------------------------------

# Django secret key - generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-this-to-a-long-random-secret-key

# Set False in production
DEBUG=True

# Comma-separated allowed hosts, e.g. localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# DATABASE (Optional - default is SQLite)
# -----------------------------------------------------------------------------

# Leave empty to use SQLite (db.sqlite3)
# For PostgreSQL example:
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/cryptostacker

# -----------------------------------------------------------------------------
# BINANCE API - Live BTC/USDT Market Data
# Website: https://www.binance.com/en/my/settings/api-management
# -----------------------------------------------------------------------------

# Public endpoints (price, chart, trades) work WITHOUT keys.
# API keys are OPTIONAL — only needed if you hit rate limits or use private endpoints later.

BINANCE_API_KEY=
BINANCE_API_SECRET=

# API base URL (change if using Binance testnet)
BINANCE_BASE_URL=https://data-api.binance.vision/api/v3

# Trading pair for live chart
BINANCE_SYMBOL=BTCUSDT

# -----------------------------------------------------------------------------
# JWT AUTH (Optional - defaults are fine for development)
# -----------------------------------------------------------------------------

# Access token lifetime in minutes (default: 1440 = 1 day)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=1440

# Refresh token lifetime in days (default: 7)
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# APP SETTINGS (Optional)
# -----------------------------------------------------------------------------

# Daily stacking profit rate base (0.014 = 1.4%) — tier rates override in code
STACK_DAILY_PROFIT_RATE=0.014

# Referral commission on approved deposit (0.12 = 12%)
REFERRAL_BONUS_RATE=0.12

# Minimum deposit / withdraw amounts (USD)
MIN_DEPOSIT=100
MIN_WITHDRAW=20

# Investment lock period after deposit (days)
INVESTMENT_LOCK_DAYS=7

# Daily bonus: referrals needed in one day / bonus amount (USD)
DAILY_BONUS_REFERRALS=3
DAILY_BONUS_AMOUNT=15

# Comma-separated frontend URLs for CORS (production)
# Example: http://localhost:5173,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# EMAIL (Optional - for future password reset / notifications)
# Provider examples: Gmail SMTP, SendGrid, Mailgun
# -----------------------------------------------------------------------------

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@cryptostacker.com

# -----------------------------------------------------------------------------
# PAYMENT GATEWAY (Optional - for real crypto deposits later)
# Examples: CoinPayments, NOWPayments, Binance Pay
# -----------------------------------------------------------------------------

# COINPAYMENTS_PUBLIC_KEY=
# COINPAYMENTS_PRIVATE_KEY=
# NOWPAYMENTS_API_KEY=
